rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Funciones auxiliares ──────────────────────────────────────────────────

    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isAuthenticated() && request.auth.uid == uid;
    }

    function isProfessor() {
      return isAuthenticated() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'professor';
    }

    function isParticipant(conversationId) {
      return isAuthenticated() &&
        request.auth.uid in get(/databases/$(database)/documents/conversations/$(conversationId)).data.participants;
    }

    // ── Usuarios ──────────────────────────────────────────────────────────────

    match /users/{uid} {
      // Solo el propio usuario puede leer y escribir su perfil
      allow read, write: if isOwner(uid);

      // Búsqueda por teléfono o correo: cualquier usuario autenticado puede leer
      // campos públicos (displayName, role, career) para búsquedas de contactos
      allow read: if isAuthenticated();

      // Subcolección de contactos: solo el propietario
      match /contacts/{contactUid} {
        allow read, write: if isOwner(uid);
      }
    }

    // ── Conversaciones ────────────────────────────────────────────────────────

    match /conversations/{conversationId} {
      // Solo los participantes pueden leer la conversación
      allow read: if isAuthenticated() &&
        request.auth.uid in resource.data.participants;

      // Cualquier usuario autenticado puede crear una conversación directa
      // Solo profesores pueden crear grupos
      allow create: if isAuthenticated() && (
        resource == null ||
        !request.resource.data.get('isGroup', false) ||
        isProfessor()
      );

      // Solo los participantes pueden actualizar (ej. lastMessage)
      allow update: if isAuthenticated() &&
        request.auth.uid in resource.data.participants;

      // Mensajes: solo participantes pueden leer/escribir
      match /messages/{messageId} {
        allow read: if isAuthenticated() &&
          request.auth.uid in get(/databases/$(database)/documents/conversations/$(conversationId)).data.participants;

        allow create: if isAuthenticated() &&
          request.auth.uid in get(/databases/$(database)/documents/conversations/$(conversationId)).data.participants &&
          request.resource.data.senderUid == request.auth.uid;

        allow update: if isAuthenticated() &&
          request.auth.uid in get(/databases/$(database)/documents/conversations/$(conversationId)).data.participants;
      }
    }

    // ── Stories ───────────────────────────────────────────────────────────────

    match /stories/{storyId} {
      // Cualquier usuario autenticado puede leer stories activos
      allow read: if isAuthenticated();

      // Solo el propietario puede crear y eliminar su story
      allow create: if isAuthenticated() &&
        request.resource.data.authorUid == request.auth.uid;

      // El propietario puede eliminar; cualquier participante puede marcar como visto
      allow update: if isAuthenticated() && (
        resource.data.authorUid == request.auth.uid ||
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['viewedBy'])
      );

      allow delete: if isAuthenticated() &&
        resource.data.authorUid == request.auth.uid;
    }

    // ── Tablón académico ──────────────────────────────────────────────────────

    match /board_posts/{postId} {
      // Cualquier usuario autenticado puede leer publicaciones
      allow read: if isAuthenticated();

      // Solo profesores pueden crear publicaciones
      allow create: if isProfessor() &&
        request.resource.data.authorUid == request.auth.uid;

      // Solo el autor puede eliminar su publicación
      allow delete: if isAuthenticated() &&
        resource.data.authorUid == request.auth.uid;

      // Cualquier usuario autenticado puede marcar como leído (actualizar readBy)
      // Solo el autor puede modificar otros campos
      allow update: if isAuthenticated() && (
        resource.data.authorUid == request.auth.uid ||
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['readBy'])
      );
    }

    // ── Llamadas ──────────────────────────────────────────────────────────────

    match /calls/{callId} {
      // Solo el emisor y receptor pueden leer/escribir la sesión de llamada
      allow read: if isAuthenticated() && (
        resource.data.callerUid == request.auth.uid ||
        resource.data.receiverUid == request.auth.uid
      );

      allow create: if isAuthenticated() &&
        request.resource.data.callerUid == request.auth.uid;

      allow update: if isAuthenticated() && (
        resource.data.callerUid == request.auth.uid ||
        resource.data.receiverUid == request.auth.uid
      );
    }
  }
}
